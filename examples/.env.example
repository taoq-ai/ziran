# ZIRAN Examples — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API keys (set whichever your chosen provider requires)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# LLM configuration (optional — defaults shown)
# ZIRAN_LLM_PROVIDER=litellm
# ZIRAN_LLM_MODEL=gpt-4o
# ZIRAN_LLM_API_KEY_ENV=OPENAI_API_KEY
# ZIRAN_LLM_TEMPERATURE=0.0
# ZIRAN_LLM_MAX_TOKENS=4096
